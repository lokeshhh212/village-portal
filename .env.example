# Copy this file to .env and fill in real values before deploying.
# Never commit the real .env file to version control.

# A long, random string used to sign JWT cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string

# Database connection string.
# SQLite (default, fine for small/low-traffic deployments):
DATABASE_URL=sqlite:///./village_portal.db

# Postgres (recommended for production, e.g. on Render/Railway):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
